#' @param n_folds Number of cross-fitting folds. Default 5.
#' @param g_bounds Numeric vector of length 2. Truncation bounds
#'   for propensity scores. Default \code{c(0.01, 0.99)}.
#' @param alpha Significance level for CIs. Default 0.05.
#' @param contrast Which contrasts to report. Default \code{"all"}.
#'   Can also be a character vector subset of
#'   \code{c("RD","ERR","RR","OR","NNT","SR","VE")}.
#'
#' @return A data.frame with columns: measure, estimate, lower, upper.
#' @export
aipw_estimate <- function(data,
outcome = "Y",
treatment = "A",
covariates,
sl_library = NULL,
ps_formula = NULL,
outcome_formula = NULL,
n_folds = 5,
g_bounds = c(0.01, 0.99),
alpha = 0.05,
contrast = "all") {
# --- Rename columns internally to A and Y ---
data$A <- data[[treatment]]
data$Y <- data[[outcome]]
n <- nrow(data)
fold_ids <- sample(rep(1:n_folds, length.out = n))
aipw_1_n <- numeric(n)
aipw_0_n <- numeric(n)
use_sl <- !is.null(sl_library)
for (k in 1:n_folds) {
train_data <- data[fold_ids != k, ]
test_data  <- data[fold_ids == k, ]
test_idx   <- which(fold_ids == k)
# Propensity score
if (use_sl) {
ps_hat <- estimate_ps_sl(train_data, test_data, covariates, sl_library)
} else {
ps_hat <- estimate_ps_glm(train_data, test_data, covariates, ps_formula)
}
ps_hat <- pmax(pmin(ps_hat, g_bounds[2]), g_bounds[1])
# Outcome model
if (use_sl) {
mu_hats <- estimate_outcome_sl(train_data, test_data, covariates, sl_library)
} else {
mu_hats <- estimate_outcome_glm(train_data, test_data, covariates, outcome_formula)
}
# AIPW pseudo-outcomes
aipw_1_n[test_idx] <- mu_hats$mu_1 +
(test_data$A / ps_hat) * (test_data$Y - mu_hats$mu_1)
aipw_0_n[test_idx] <- mu_hats$mu_0 +
((1 - test_data$A) / (1 - ps_hat)) * (test_data$Y - mu_hats$mu_0)
}
# Compute all contrasts with influence-function-based CIs
results <- compute_contrasts(aipw_1_n, aipw_0_n, alpha = alpha)
# Filter contrasts if requested
if (!identical(contrast, "all")) {
valid <- c("RD", "ERR", "RR", "OR", "NNT", "SR", "VE")
bad <- setdiff(contrast, valid)
if (length(bad) > 0) {
stop("Unknown contrast(s): ", paste(bad, collapse = ", "),
". Choose from: ", paste(valid, collapse = ", "))
}
results <- results[results$measure %in% contrast, ]
}
rownames(results) <- NULL
class(results) <- c("aipw_result", "data.frame")
results
}
#' Print method for aipw_result
#' @param x An aipw_result object.
#' @param digits Number of digits. Default 4.
#' @param ... Ignored.
#' @export
print.aipw_result <- function(x, digits = 4, ...) {
cat("\n=== AIPW Causal Estimates ===\n\n")
fmt <- x
fmt$estimate <- round(fmt$estimate, digits)
fmt$lower    <- round(fmt$lower, digits)
fmt$upper    <- round(fmt$upper, digits)
print.data.frame(fmt, row.names = FALSE)
cat("\n")
invisible(x)
}
#' List Available Causal Contrasts
#'
#' @return A data.frame describing each supported contrast.
#' @export
available_contrasts <- function() {
data.frame(
contrast    = c("RD", "ERR", "RR", "OR", "NNT", "SR", "VE"),
name        = c("Risk Difference",
"Excess Relative Risk",
"Risk Ratio",
"Odds Ratio",
"Number Needed to Treat",
"Survival Ratio",
"Vaccine Efficacy"),
formula     = c("P(Y=1|A=1) - P(Y=1|A=0)",
"[P(Y=1|A=1) - P(Y=1|A=0)] / P(Y=1|A=0)",
"P(Y=1|A=1) / P(Y=1|A=0)",
"[P(Y=1|A=1)/P(Y=0|A=1)] / [P(Y=1|A=0)/P(Y=0|A=0)]",
"1 / |RD|",
"[1-P(Y=1|A=1)] / [1-P(Y=1|A=0)]",
"1 - RR"),
ci_method   = c("Wald", "log-transform via RR", "log-transform",
"log-transform", "log-transform", "log-transform",
"log-transform via RR"),
stringsAsFactors = FALSE
)
}
#' List Available SuperLearner Libraries
#'
#' @return A data.frame of algorithm names, categories, and
#'   required packages.
#' @export
available_sl_libraries <- function() {
data.frame(
algorithm        = c("SL.glm", "SL.glm.interaction", "SL.step",
"SL.step.interaction", "SL.bayesglm",
"SL.ranger", "SL.xgboost", "SL.earth",
"SL.nnet", "SL.svm", "SL.glmnet", "SL.gam",
"SL.mean"),
category         = c(rep("parametric", 5),
rep("machine_learning", 7),
"nonparametric"),
package_required = c("stats", "stats", "stats", "stats", "arm",
"ranger", "xgboost", "earth",
"nnet", "e1071", "glmnet", "mgcv",
"SuperLearner"),
stringsAsFactors = FALSE
)
}
#' AIPW Bootstrap Confidence Intervals
#'
#' Nonparametric bootstrap wrapper around \code{\link{aipw_estimate}}.
#'
#' @inheritParams aipw_estimate
#' @param n_boot Number of bootstrap replicates. Default 200.
#'
#' @return A data.frame with columns: measure, estimate, lower, upper.
#' @export
aipw_bootstrap <- function(data,
outcome = "Y",
treatment = "A",
covariates,
sl_library = NULL,
ps_formula = NULL,
outcome_formula = NULL,
n_folds = 5,
g_bounds = c(0.01, 0.99),
alpha = 0.05,
contrast = "all",
n_boot = 200) {
# Original estimate
orig <- aipw_estimate(
data = data, outcome = outcome, treatment = treatment,
covariates = covariates, sl_library = sl_library,
ps_formula = ps_formula, outcome_formula = outcome_formula,
n_folds = n_folds, g_bounds = g_bounds, alpha = alpha,
contrast = "all"
)
n <- nrow(data)
measures <- c("RD", "ERR", "RR", "OR", "NNT", "SR", "VE")
boot_mat <- matrix(NA, nrow = n_boot, ncol = 7,
dimnames = list(NULL, measures))
for (b in seq_len(n_boot)) {
boot_data <- data[sample(n, n, replace = TRUE), ]
boot_res <- tryCatch(
aipw_estimate(
data = boot_data, outcome = outcome, treatment = treatment,
covariates = covariates, sl_library = sl_library,
ps_formula = ps_formula, outcome_formula = outcome_formula,
n_folds = n_folds, g_bounds = g_bounds, alpha = alpha,
contrast = "all"
),
error = function(e) NULL
)
if (!is.null(boot_res)) {
boot_mat[b, ] <- boot_res$estimate[match(measures, boot_res$measure)]
}
}
probs <- c(alpha / 2, 1 - alpha / 2)
# RD: quantile on original scale
RD_ci <- stats::quantile(boot_mat[, "RD"], probs, na.rm = TRUE)
# Log-scale CIs for RR, OR, NNT, SR
log_measures <- c("RR", "OR", "NNT", "SR")
log_boot <- log(boot_mat[, log_measures])
log_ci <- apply(log_boot, 2, stats::quantile, probs = probs, na.rm = TRUE)
# ERR = RR - 1
ERR_ci <- exp(log_ci[, "RR"]) - 1
# VE = 1 - RR (flip bounds)
VE_ci <- 1 - exp(rev(log_ci[, "RR"]))
results <- data.frame(
measure  = measures,
estimate = orig$estimate[match(measures, orig$measure)],
lower    = c(RD_ci[1], ERR_ci[1], exp(log_ci[1, "RR"]),
exp(log_ci[1, "OR"]), exp(log_ci[1, "NNT"]),
exp(log_ci[1, "SR"]), VE_ci[1]),
upper    = c(RD_ci[2], ERR_ci[2], exp(log_ci[2, "RR"]),
exp(log_ci[2, "OR"]), exp(log_ci[2, "NNT"]),
exp(log_ci[2, "SR"]), VE_ci[2]),
stringsAsFactors = FALSE
)
rownames(results) <- NULL
# Filter contrasts
if (!identical(contrast, "all")) {
results <- results[results$measure %in% contrast, ]
}
class(results) <- c("aipw_result", "data.frame")
results
}
set.seed(42)
n <- 500
W1 <- rnorm(n); W2 <- rbinom(n, 1, 0.5)
pi <- rnorm(n)
A <- rbinom(n, 1, plogis(0.5 * W1 + 0.3 * W2))
Y <- rbinom(n, 1, plogis(-1 + A + 0.5 * W1))
dat <- data.frame(Y = Y, A = A, W1 = W1, W2 = W2, pi = pi)
aipw_estimate(dat, outcome = "Y", treatment = "A",
covariates = c("W1", "W2"),
sl_library = c("SL.glm", "SL.earth"))
#' @import SuperLearner
NULL
#' @keywords internal
estimate_ps_glm <- function(train_data, test_data, covariates, ps_formula = NULL) {
if (!is.null(ps_formula)) {
fit <- stats::glm(ps_formula, data = train_data, family = stats::binomial())
} else {
fml <- stats::as.formula(paste("A ~", paste(covariates, collapse = " + ")))
fit <- stats::glm(fml, data = train_data, family = stats::binomial())
}
stats::predict(fit, newdata = test_data, type = "response")
}
#' @keywords internal
estimate_ps_sl <- function(train_data, test_data, covariates, sl_library) {
X_train <- train_data[, covariates, drop = FALSE]
X_test <- test_data[, covariates, drop = FALSE]
sl_fit <- SuperLearner::SuperLearner(
Y = train_data$A, X = X_train,
family = stats::binomial(),
SL.library = sl_library,
verbose = FALSE
)
as.numeric(SuperLearner::predict.SuperLearner(sl_fit, newdata = X_test)$pred)
}
#' @keywords internal
estimate_outcome_glm <- function(train_data, test_data, covariates, outcome_formula = NULL) {
train_1 <- train_data[train_data$A == 1, ]
train_0 <- train_data[train_data$A == 0, ]
if (!is.null(outcome_formula)) {
fit_1 <- stats::glm(outcome_formula, data = train_1, family = stats::binomial())
fit_0 <- stats::glm(outcome_formula, data = train_0, family = stats::binomial())
} else {
fml <- stats::as.formula(paste("Y ~", paste(covariates, collapse = " + ")))
fit_1 <- stats::glm(fml, data = train_1, family = stats::binomial())
fit_0 <- stats::glm(fml, data = train_0, family = stats::binomial())
}
mu_1 <- stats::predict(fit_1, newdata = test_data, type = "response")
mu_0 <- stats::predict(fit_0, newdata = test_data, type = "response")
list(mu_1 = mu_1, mu_0 = mu_0)
}
#' @keywords internal
estimate_outcome_sl <- function(train_data, test_data, covariates, sl_library) {
train_1 <- train_data[train_data$A == 1, ]
train_0 <- train_data[train_data$A == 0, ]
X_1 <- train_1[, covariates, drop = FALSE]
X_0 <- train_0[, covariates, drop = FALSE]
X_test <- test_data[, covariates, drop = FALSE]
sl_fit_1 <- SuperLearner::SuperLearner(
Y = train_1$Y, X = X_1,
family = stats::binomial(),
SL.library = sl_library, method = "method.NNLS", verbose = FALSE
)
sl_fit_0 <- SuperLearner::SuperLearner(
Y = train_0$Y, X = X_0,
family = stats::binomial(),
SL.library = sl_library, method = "method.NNLS", verbose = FALSE
)
mu_1 <- as.numeric(SuperLearner::predict.SuperLearner(sl_fit_1, newdata = X_test)$pred)
mu_0 <- as.numeric(SuperLearner::predict.SuperLearner(sl_fit_0, newdata = X_test)$pred)
list(mu_1 = mu_1, mu_0 = mu_0)
}
#' @keywords internal
compute_contrasts <- function(aipw_1_n, aipw_0_n, alpha = 0.05) {
n <- length(aipw_1_n)
psi_1 <- mean(aipw_1_n)
psi_0 <- mean(aipw_0_n)
# Point estimates
RD  <- psi_1 - psi_0
RR  <- psi_1 / psi_0
ERR <- (psi_1 - psi_0) / psi_0
OR  <- (psi_1 / (1 - psi_1)) / (psi_0 / (1 - psi_0))
NNT <- abs(1 / RD)
SR  <- (1 - psi_1) / (1 - psi_0)
VE  <- 1 - RR
# Influence functions
IF_psi1 <- aipw_1_n - psi_1
IF_psi0 <- aipw_0_n - psi_0
IF_RD     <- IF_psi1 - IF_psi0
IF_logRR  <- (1 / psi_1) * IF_psi1 - (1 / psi_0) * IF_psi0
IF_logOR  <- (1 / psi_1 + 1 / (1 - psi_1)) * IF_psi1 +
(-1 / (1 - psi_0) - 1 / psi_0) * IF_psi0
IF_logNNT <- (1 / (psi_0 - psi_1)) * IF_psi1 +
(-1 / (psi_0 - psi_1)) * IF_psi0
IF_logSR  <- (-1 / (1 - psi_1)) * IF_psi1 +
(1 / (1 - psi_0)) * IF_psi0
# Standard errors
se_RD  <- sqrt(stats::var(IF_RD) / n)
se_log <- sapply(
list(IF_logRR, IF_logOR, IF_logNNT, IF_logSR),
function(x) sqrt(stats::var(x) / n)
)
z <- stats::qnorm(1 - alpha / 2)
# RD: Wald CI on identity scale
RD_lower <- RD - z * se_RD
RD_upper <- RD + z * se_RD
# Log-scale CIs for RR, OR, NNT, SR
log_est   <- log(c(RR, OR, NNT, SR))
log_lower <- log_est - z * se_log
log_upper <- log_est + z * se_log
# ERR = RR - 1
ERR_lower <- exp(log_lower[1]) - 1
ERR_upper <- exp(log_upper[1]) - 1
# VE = 1 - RR (bounds flip)
VE_lower <- 1 - exp(log_upper[1])
VE_upper <- 1 - exp(log_lower[1])
data.frame(
measure   = c("RD", "ERR", "RR", "OR", "NNT", "SR", "VE"),
estimate  = c(RD,   ERR,   RR,   OR,   NNT,   SR,   VE),
lower     = c(RD_lower, ERR_lower, exp(log_lower[1]),
exp(log_lower[2]), exp(log_lower[3]),
exp(log_lower[4]), VE_lower),
upper     = c(RD_upper, ERR_upper, exp(log_upper[1]),
exp(log_upper[2]), exp(log_upper[3]),
exp(log_upper[4]), VE_upper),
stringsAsFactors = FALSE
)
}
#' AIPW Estimator with Cross-Fitting
#'
#' @param data A data.frame with columns named by \code{outcome},
#'   \code{treatment}, and \code{covariates}.
#' @param outcome Character. Name of binary outcome column (0/1).
#' @param treatment Character. Name of binary treatment column (0/1).
#' @param covariates Character vector of covariate column names.
#' @param sl_library Character vector of SuperLearner algorithms, or
#'   \code{NULL} to use parametric GLM instead.
#' @param ps_formula Optional formula for propensity score GLM
#'   (ignored when \code{sl_library} is not NULL).
#' @param outcome_formula Optional formula for outcome GLM
#'   (ignored when \code{sl_library} is not NULL).
#' @param n_folds Number of cross-fitting folds. Default 5.
#' @param g_bounds Numeric vector of length 2. Truncation bounds
#'   for propensity scores. Default \code{c(0.01, 0.99)}.
#' @param alpha Significance level for CIs. Default 0.05.
#' @param contrast Which contrasts to report. Default \code{"all"}.
#'   Can also be a character vector subset of
#'   \code{c("RD","ERR","RR","OR","NNT","SR","VE")}.
#'
#' @return A data.frame with columns: measure, estimate, lower, upper.
#' @export
aipw_estimate <- function(data,
outcome = "Y",
treatment = "A",
covariates,
sl_library = NULL,
ps_formula = NULL,
outcome_formula = NULL,
n_folds = 5,
g_bounds = c(0.01, 0.99),
alpha = 0.05,
contrast = "all") {
# --- Rename columns internally to A and Y ---
data$A <- data[[treatment]]
data$Y <- data[[outcome]]
n <- nrow(data)
fold_ids <- sample(rep(1:n_folds, length.out = n))
aipw_1_n <- numeric(n)
aipw_0_n <- numeric(n)
use_sl <- !is.null(sl_library)
for (k in 1:n_folds) {
train_data <- data[fold_ids != k, ]
test_data  <- data[fold_ids == k, ]
test_idx   <- which(fold_ids == k)
# Propensity score
if (use_sl) {
ps_hat <- estimate_ps_sl(train_data, test_data, covariates, sl_library)
} else {
ps_hat <- estimate_ps_glm(train_data, test_data, covariates, ps_formula)
}
ps_hat <- pmax(pmin(ps_hat, g_bounds[2]), g_bounds[1])
# Outcome model
if (use_sl) {
mu_hats <- estimate_outcome_sl(train_data, test_data, covariates, sl_library)
} else {
mu_hats <- estimate_outcome_glm(train_data, test_data, covariates, outcome_formula)
}
# AIPW pseudo-outcomes
aipw_1_n[test_idx] <- mu_hats$mu_1 +
(test_data$A / ps_hat) * (test_data$Y - mu_hats$mu_1)
aipw_0_n[test_idx] <- mu_hats$mu_0 +
((1 - test_data$A) / (1 - ps_hat)) * (test_data$Y - mu_hats$mu_0)
}
# Compute all contrasts with influence-function-based CIs
results <- compute_contrasts(aipw_1_n, aipw_0_n, alpha = alpha)
# Filter contrasts if requested
if (!identical(contrast, "all")) {
valid <- c("RD", "ERR", "RR", "OR", "NNT", "SR", "VE")
bad <- setdiff(contrast, valid)
if (length(bad) > 0) {
stop("Unknown contrast(s): ", paste(bad, collapse = ", "),
". Choose from: ", paste(valid, collapse = ", "))
}
results <- results[results$measure %in% contrast, ]
}
rownames(results) <- NULL
class(results) <- c("aipw_result", "data.frame")
results
}
#' Print method for aipw_result
#' @param x An aipw_result object.
#' @param digits Number of digits. Default 4.
#' @param ... Ignored.
#' @export
print.aipw_result <- function(x, digits = 4, ...) {
cat("\n=== AIPW Causal Estimates ===\n\n")
fmt <- x
fmt$estimate <- round(fmt$estimate, digits)
fmt$lower    <- round(fmt$lower, digits)
fmt$upper    <- round(fmt$upper, digits)
print.data.frame(fmt, row.names = FALSE)
cat("\n")
invisible(x)
}
aipw_estimate(dat, outcome = "Y", treatment = "A",
covariates = c("W1", "W2"),
sl_library = c("SL.glm", "SL.earth"))
